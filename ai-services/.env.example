# AI Service Configuration
PORT=8000
HOST=0.0.0.0

# Backend URL (for posting alerts)
BACKEND_URL=http://localhost:5000

# Model paths
YOLO_MODEL_PATH=models/yolov8n.pt

# Thresholds
GAZE_AWAY_THRESHOLD=0.35        # Normalized gaze offset to flag
HEAD_POSE_YAW_THRESHOLD=35      # Degrees yaw to flag head turn
HEAD_POSE_PITCH_THRESHOLD=25    # Degrees pitch to flag head tilt
FACE_CONFIDENCE_MIN=0.6         # Minimum face detection confidence
WHISPER_MODEL=base               # tiny/base/small/medium/large
MULTI_VOICE_THRESHOLD=0.5       # Score for detecting multiple voices
MIN_SILENCE_DURATION=0.3        # Minimum silence duration (s)

# Logging
LOG_LEVEL=INFO
